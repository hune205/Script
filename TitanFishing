local function getHWID()
    local ok, id = pcall(function()
        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    if ok and id and id ~= "" then return id end
    if gethwid then return gethwid() end
    return "ROBLOX_" .. tostring(Players.LocalPlayer.UserId)
end
local HWID = getHWID()

local function validateKey(key)
    local url = API_URL .. "/api/verify?key=" .. key .. "&hwid=" .. HWID
    local ok, result = pcall(function()
        if request then
            return HttpService:JSONDecode(request({ Url = url, Method = "GET" }).Body)
        elseif syn and syn.request then
            return HttpService:JSONDecode(syn.request({ Url = url, Method = "GET" }).Body)
        elseif http_request then
            return HttpService:JSONDecode(http_request({ Url = url, Method = "GET" }).Body)
        else
            return HttpService:JSONDecode(game:HttpGet(url))
        end
    end)
    if ok and result then return result.success == true end
    return false
end

local function saveKey(key)
    if writefile then pcall(writefile, FILE_NAME, key) end
end

if isfile and isfile(FILE_NAME) then
    local ok, saved = pcall(readfile, FILE_NAME)
    if ok and saved and saved ~= "" then
        if validateKey(saved:match("^%s*(.-)%s*$")) then
            loadstring(game:HttpGet("https://raw.hune205.dev/Script/TitanFishing.lua"))()
            return
        else
            pcall(delfile, FILE_NAME)
        end
    end
end

