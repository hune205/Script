local isProcessing = false
VerifyBtn.MouseButton1Click:Connect(function()
    if isProcessing then return end
    isProcessing = true
    local key = KeyInput.Text:match("^%s*(.-)%s*$")
    if key == "" then
        setStatus("Please enter your key first.", Color3.fromRGB(243, 139, 168))
        tw(VerifyBtn, 0.15, { BackgroundColor3 = Color3.fromRGB(243, 139, 168) })
        task.delay(1.4, function()
            tw(VerifyBtn, 0.15, { BackgroundColor3 = Color3.fromRGB(137, 180, 250) })
            setStatus("")
            isProcessing = false
        end)
        return
    end
    VerifyBtn.Text = "Checking..."
    setStatus("Contacting server...", Color3.fromRGB(166, 173, 200))
    task.spawn(function()
        local valid = validateKey(key)
        if valid then
            saveKey(key)
            VerifyBtn.Text = "Verified!"
            tw(VerifyBtn, 0.2, { BackgroundColor3 = Color3.fromRGB(166, 227, 161) })
            setStatus("Key valid! Loading Hune Hub...", Color3.fromRGB(166, 227, 161))
            task.wait(0.9)
            closeUI(function()
                loadstring(game:HttpGet("https://raw.hune205.dev/Script/TitanFishing.lua"))()
            end)
        else
            VerifyBtn.Text = "Invalid Key!"
            tw(VerifyBtn, 0.15, { BackgroundColor3 = Color3.fromRGB(243, 139, 168) })
            setStatus("Key is invalid or expired.", Color3.fromRGB(243, 139, 168))
            task.delay(1.8, function()
                VerifyBtn.Text = "Verify Key"
                tw(VerifyBtn, 0.15, { BackgroundColor3 = Color3.fromRGB(137, 180, 250) })
                setStatus("")
                isProcessing = false
            end)
        end
    end)
end)
