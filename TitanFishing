    tw(NeonBorder, 0.35, { BackgroundTransparency = 1 })
    tw(Panel,      0.35, { Size = UDim2.fromOffset(405, 275), BackgroundTransparency = 1 })
    tw(Logo,       0.25, { ImageTransparency = 1 })
    tw(Title,      0.25, { TextTransparency = 1 })
    tw(Sub,        0.25, { TextTransparency = 1 })
    tw(InputWrap,  0.25, { BackgroundTransparency = 1 })
    tw(KeyInput,   0.25, { TextTransparency = 1 })
    tw(GetKeyBtn,  0.25, { BackgroundTransparency = 1, TextTransparency = 1 })
    tw(VerifyBtn,  0.25, { BackgroundTransparency = 1, TextTransparency = 1 })
    tw(Overlay,    0.4,  { BackgroundTransparency = 1 })
    tw(Blur,       0.5,  { Size = 0 })
